{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "LLM RAG Pipeline",
  "uid": "llm-rag-pipeline",
  "tags": ["rag", "spring-ai"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{application=\"llm-rag-pipeline\"}[1m]))",
          "legendFormat": "{{uri}} ({{status}})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{application=\"llm-rag-pipeline\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Retrieval latency p95 (s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rag_retrieval_seconds_bucket{application=\"llm-rag-pipeline\"}[5m])))",
          "legendFormat": "retrieval p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{application=\"llm-rag-pipeline\"})",
          "legendFormat": "{{area}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Retrieval quality (last eval run)",
      "description": "Updated by POST /api/admin/eval/run against the qrels.json gold set.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "decimals": 3, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.75 } ] } } },
      "targets": [
        { "expr": "rag_eval_mrr{application=\"llm-rag-pipeline\"}", "legendFormat": "MRR" },
        { "expr": "rag_eval_context_precision{application=\"llm-rag-pipeline\"}", "legendFormat": "Context Precision" },
        { "expr": "rag_eval_precision_at_k{application=\"llm-rag-pipeline\"}", "legendFormat": "Precision@k" },
        { "expr": "rag_eval_recall_at_k{application=\"llm-rag-pipeline\"}", "legendFormat": "Recall@k" }
      ]
    }
  ]
}
